# ============================================================
# 敏感数据文件（！！重要！！）
# ============================================================
.env
.env.local
.env.*.local

# 用户数据和白名单（包含敏感的用户 ID）
data/whitelist.json
data/chatID.json
data/ZincNyaQuotes.json
data/chatHistory.db
data/.chatKey
data/chatExport/
data/chatBackup/
data/todos.db
data/operators.json
data/pushedNews.json
data/prompts.json
data/llmConfig.json
data/llmMemory.db
data/zincnya_backup/
# LLM 子目录（迁移后的新路径）
data/llm/prompts.json
data/llm/llmConfig.json
data/llm/llmMemory.db
data/llm/knowledge.db
# 知识库 Markdown（含人设细节，与 prompts.json 同密级）
# 模板见 data/llm/knowledge.example/
data/llm/knowledge/
# SQLite WAL/SHM sidecar 文件（运行时自动产生，包含未提交的事务数据）
data/*.db-wal
data/*.db-shm
data/*.db-journal
data/llm/*.db-wal
data/llm/*.db-shm
data/llm/*.db-journal
# 模块管理系统的本地状态（启用偏好、自定义模块、强制卸载名单），每个部署实例独有
data/modules.json
data/modulesCustom.json
data/modulesUninstalled.json
# AFC 工具管理的运行时状态（启用开关、第三方工具清单），每个部署实例独有。
# 注意：data/afcToolsBuiltin.json 是仓库提供的内置工具清单，不忽略。
data/afcTools.json
data/afcToolsCustom.json
# install/update 的暂存与回滚备份目录（失败时残留用于人工抢救），运行时生成。
data/.afc_install/
# 但保留 .gitkeep 占位文件
!data/.gitkeep


# ============================================================
# FFmpeg 二进制文件（体积大，请参考 ffmpeg/README.md 获取配置说明）
# ============================================================
ffmpeg/*.exe
ffmpeg/ffmpeg
ffmpeg/ffprobe
# 但保留说明文档
!ffmpeg/README.md


# ============================================================
# 操作系统相关
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini


# ============================================================
# 测试和覆盖率
# ============================================================
htmlcov/
.coverage
coverage.xml
.pytest_cache/


# ============================================================
# 其他
# ============================================================
*.bak
*.tmp
*.swp
