# ============================================================
# ZincNya Bot 环境变量配置模板
# ============================================================
#
# 使用说明喵：
# 1. 把这个文件复制一份并重命名为 .env
# 2. 填入你的实际配置信息
# 3. .env 文件不会被提交到 git（已经在 .gitignore 中忽略了喵）
#

# Telegram Bot Token（必需喵！）
# 从 @BotFather 那里获取
BOT_TOKEN=your_bot_token_here

# Telegram 代理配置（可选喵）
# 如果无法连接 Telegram 服务器，可以配置代理
# 格式: http://host:port
# TELEGRAM_PROXY=http://127.0.0.1:7897

# Open Library API 代理配置（可选喵）
# 如果访问 Open Library API（书籍搜索）较慢，可以配置代理
# 格式: http://host:port 或 http://user:pass@host:port
# BOOK_HTTP_PROXY=http://127.0.0.1:7897

# Claude LLM API 密钥（可选喵，用于 /llm 功能）
# 从 https://console.anthropic.com/settings/keys 获取
# ANTHROPIC_API_KEY=sk-ant-api...

# 远程服务器配置（用于 sync-data.ps1，可选喵）
# 用于在本地和远程服务器之间同步 data/ 目录
# REMOTE_HOST=user@your.server.ip
# REMOTE_PORT=22
# REMOTE_PATH=ZincNya_bot/data/
